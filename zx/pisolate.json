{
  "schemaVersion": 1,
  "name": "zx",
  "version": "0.3.0",
  "description": "Full-access Pi harness for focused zsh wrapper/config work under ~/.config.",
  "category": "config",
  "prompt": "prompt.md",
  "readme": "README.md",
  "oraclePlan": "oracle-plan.md",
  "defaultRoot": "~/.config",
  "modes": {
    "interactive": {
      "kind": "interactive",
      "commands": [
        "pi-zx"
      ],
      "policy": "full-cli-access",
      "pi": {
        "mode": "interactive",
        "tools": [
          "bash",
          "edit"
        ],
        "session": "save",
        "promptMode": "append",
        "disableAmbientResources": true,
        "disableContextFilesWhenSupported": true
      }
    },
    "oneShot": {
      "kind": "one-shot",
      "commands": [
        "p-zx"
      ],
      "policy": "full-cli-access",
      "pi": {
        "mode": "print",
        "tools": [
          "bash",
          "edit"
        ],
        "session": "ephemeral",
        "promptMode": "append",
        "disableAmbientResources": true,
        "disableContextFilesWhenSupported": true
      }
    }
  },
  "requires": {
    "executables": [
      {
        "name": "pi",
        "command": "pi",
        "versionCommand": "pi --version"
      },
      {
        "name": "zsh",
        "command": "zsh",
        "versionCommand": "zsh --version"
      },
      {
        "name": "git",
        "command": "git",
        "versionCommand": "git --version"
      }
    ]
  },
  "pathPolicy": {
    "default": "allow",
    "readable": [
      {
        "path": "AGENTS.md",
        "mustExist": false,
        "reason": "repo agent rules"
      },
      {
        "path": "CLAUDE.md",
        "mustExist": false,
        "reason": "repo development notes"
      },
      {
        "path": "zsh/conf.d/49-codex-bare-dsl.zsh",
        "mustExist": true,
        "reason": "primary wrapper module"
      },
      {
        "path": "zsh/tests/49-codex-bare-dsl-kx.zsh",
        "mustExist": false,
        "reason": "focused wrapper test example"
      },
      {
        "path": "zsh/tests/49-codex-bare-dsl-zx.zsh",
        "mustExist": true,
        "reason": "focused zx wrapper test"
      },
      {
        "path": "zsh/tests/startup-regression.zsh",
        "mustExist": false,
        "reason": "read-only startup regression reference"
      }
    ],
    "editable": [
      {
        "path": "zsh/conf.d/49-codex-bare-dsl.zsh",
        "mustExist": true,
        "create": false,
        "reason": "primary zx wrapper module"
      },
      {
        "path": "zsh/tests/49-codex-bare-dsl-zx.zsh",
        "mustExist": true,
        "create": false,
        "reason": "focused zx test"
      }
    ],
    "legacyReadOnly": [],
    "generatedReadOnly": [],
    "sensitiveDenied": []
  },
  "commandPolicy": {
    "default": "allow",
    "shell": {
      "denyShellMetacharacters": false,
      "denyMultiline": false,
      "allowPipes": true,
      "allowRedirects": true
    },
    "allowed": [
      {
        "id": "all-commands",
        "match": "^.*$",
        "kind": "full-access",
        "reason": "Full CLI access is the default for this pisolate."
      }
    ],
    "denied": [],
    "writeCommands": [],
    "destructiveCommands": [],
    "sensitivePaths": [],
    "nonInteractiveConfirmation": "allow"
  },
  "install": {
    "conflictPolicy": "overwrite-managed-only",
    "linkStrategy": "copy",
    "shellIntegration": "ask"
  },
  "smokeChecks": [
    {
      "name": "policy allows target command",
      "command": "scripts/test-command-policy zx 'codex exec hello'",
      "expectExit": 0
    },
    {
      "name": "policy allows shell chaining",
      "command": "scripts/test-command-policy zx 'codex exec hello && pwd'",
      "expectExit": 0
    },
    {
      "name": "path policy allows arbitrary edit",
      "command": "scripts/test-path-policy zx edit unrestricted-test.txt",
      "expectExit": 0
    }
  ],
  "compat": {
    "minPiVersion": "0.67.3",
    "testedPiVersions": [
      "0.67.3"
    ],
    "requiredPiFlags": [
      "--tools",
      "--append-system-prompt",
      "--session-dir",
      "--no-session"
    ],
    "optionalPiFlags": [
      "--no-context-files"
    ],
    "notes": "This recipe intentionally defaults to full target-CLI access. Pisolates still provides isolated launcher/session/prompt structure, but command use is not curated."
  }
}
