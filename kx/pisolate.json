{
  "schemaVersion": 1,
  "name": "kx",
  "version": "0.2.0",
  "description": "Full-access Pi harness for editing Karabiner kar config.ts with dry-run verification.",
  "category": "config",
  "prompt": "prompt.md",
  "readme": "README.md",
  "oraclePlan": "oracle-plan.md",
  "defaultRoot": "~/.config",
  "targetCli": {
    "name": "kar",
    "preferredPath": "~/.local/bin/kar",
    "resolve": "path",
    "helpCommand": "kar --help"
  },
  "env": {
    "KX_CONFIG_ROOT": "~/.config",
    "KX_KAR_CONFIG": "~/.config/kar-migration/config.ts"
  },
  "modes": {
    "interactive": {
      "kind": "interactive",
      "commands": [
        "pi-kx"
      ],
      "policy": "full-cli-access",
      "pi": {
        "mode": "interactive",
        "tools": [
          "bash",
          "edit"
        ],
        "session": "save",
        "promptMode": "append",
        "disableAmbientResources": true,
        "disableContextFilesWhenSupported": true
      }
    },
    "oneShot": {
      "kind": "one-shot",
      "commands": [
        "p-kx"
      ],
      "policy": "full-cli-access",
      "pi": {
        "mode": "print",
        "tools": [
          "bash",
          "edit"
        ],
        "session": "ephemeral",
        "promptMode": "append",
        "disableAmbientResources": true,
        "disableContextFilesWhenSupported": true
      }
    }
  },
  "requires": {
    "executables": [
      {
        "name": "pi",
        "command": "pi",
        "versionCommand": "pi --version"
      },
      {
        "name": "kar",
        "command": "kar",
        "versionCommand": "kar --help"
      },
      {
        "name": "rg",
        "command": "rg",
        "versionCommand": "rg --version"
      },
      {
        "name": "git",
        "command": "git",
        "versionCommand": "git --version"
      }
    ]
  },
  "pathPolicy": {
    "default": "allow",
    "editable": [
      {
        "path": "kar-migration/config.ts",
        "mustExist": true,
        "create": false,
        "reason": "Primary kx source file."
      }
    ],
    "readable": [
      "AGENTS.md",
      "kar-migration/config.ts",
      "kar-migration/types/index.ts",
      "kar-migration/generated/manifest.json",
      "kar-migration/generated/profile.generated.ts",
      "kar-migration/generated/raw-rules.generated.ts",
      "kar-migration/generated/raw-simple.generated.ts",
      "kar-migration/reports/final-verification.md",
      "kar-migration/reports/source-coverage.md",
      "karabiner/karabiner.json"
    ],
    "generatedReadOnly": [],
    "legacyReadOnly": [],
    "sensitiveDenied": []
  },
  "commandPolicy": {
    "default": "allow",
    "shell": {
      "denyShellMetacharacters": false,
      "denyMultiline": false,
      "allowPipes": true,
      "allowRedirects": true
    },
    "allowed": [
      {
        "id": "all-commands",
        "match": "^.*$",
        "kind": "full-access",
        "reason": "Full CLI access is the default for this pisolate."
      }
    ],
    "denied": [],
    "writeCommands": [],
    "destructiveCommands": [],
    "sensitivePaths": [],
    "nonInteractiveConfirmation": "allow"
  },
  "install": {
    "conflictPolicy": "overwrite-managed-only",
    "linkStrategy": "copy",
    "shellIntegration": "ask"
  },
  "smokeChecks": [
    {
      "name": "policy allows target command",
      "command": "scripts/test-command-policy kx 'kar -c kar-migration/config.ts'",
      "expectExit": 0
    },
    {
      "name": "policy allows shell chaining",
      "command": "scripts/test-command-policy kx 'kar -c kar-migration/config.ts && pwd'",
      "expectExit": 0
    },
    {
      "name": "path policy allows arbitrary edit",
      "command": "scripts/test-path-policy kx edit unrestricted-test.txt",
      "expectExit": 0
    }
  ],
  "compat": {
    "minPiVersion": "0.67.3",
    "testedPiVersions": [
      "0.67.3"
    ],
    "requiredPiFlags": [
      "--tools",
      "--append-system-prompt",
      "--session-dir",
      "--no-session"
    ],
    "optionalPiFlags": [
      "--no-context-files"
    ],
    "notes": "This recipe intentionally defaults to full target-CLI access. Pisolates still provides isolated launcher/session/prompt structure, but command use is not curated."
  }
}
