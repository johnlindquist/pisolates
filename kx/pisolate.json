{
  "schemaVersion": 1,
  "name": "kx",
  "version": "0.2.0",
  "description": "Full-access Pi harness for editing Karabiner kar config.ts with dry-run verification.",
  "category": "config",
  "prompt": "prompt.md",
  "readme": "README.md",
  "oraclePlan": "oracle-plan.md",
  "defaultRoot": "~/.config",
  "targetCli": {
    "name": "kar",
    "preferredPath": "~/.local/bin/kar",
    "resolve": "path",
    "helpCommand": "kar --help"
  },
  "env": {
    "KX_CONFIG_ROOT": "~/.config",
    "KX_KAR_CONFIG": "~/.config/kar-migration/config.ts"
  },
  "modes": {
    "interactive": {
      "kind": "interactive",
      "commands": [
        "pi-kx"
      ],
      "policy": "full-cli-access",
      "pi": {
        "mode": "interactive",
        "tools": [
          "read",
          "bash",
          "edit",
          "write",
          "grep",
          "find",
          "ls"
        ],
        "session": "save",
        "promptMode": "append",
        "disableAmbientResources": true,
        "disableContextFilesWhenSupported": true,
        "yolo": true
      }
    },
    "oneShot": {
      "kind": "one-shot",
      "commands": [
        "p-kx"
      ],
      "policy": "full-cli-access",
      "pi": {
        "mode": "print",
        "tools": [
          "read",
          "bash",
          "edit",
          "write",
          "grep",
          "find",
          "ls"
        ],
        "session": "ephemeral",
        "promptMode": "append",
        "disableAmbientResources": true,
        "disableContextFilesWhenSupported": true,
        "yolo": true
      }
    }
  },
  "requires": {
    "executables": [
      {
        "name": "pi",
        "command": "pi",
        "versionCommand": "pi --version"
      },
      {
        "name": "kar",
        "command": "kar",
        "versionCommand": "kar --help"
      },
      {
        "name": "rg",
        "command": "rg",
        "versionCommand": "rg --version"
      },
      {
        "name": "git",
        "command": "git",
        "versionCommand": "git --version"
      }
    ]
  },
  "pathPolicy": {
    "default": "allow",
    "editable": [],
    "readable": [],
    "generatedReadOnly": [],
    "legacyReadOnly": [],
    "sensitiveDenied": [],
    "allowOutsideWorkingRoot": true
  },
  "commandPolicy": {
    "default": "allow",
    "shell": {
      "denyShellMetacharacters": false,
      "denyMultiline": false,
      "allowPipes": true,
      "allowRedirects": true
    },
    "allowed": [
      {
        "id": "all-commands",
        "match": "^.*$",
        "kind": "full-access",
        "reason": "Full CLI access is the default for this pisolate."
      }
    ],
    "denied": [],
    "writeCommands": [],
    "destructiveCommands": [],
    "sensitivePaths": [],
    "nonInteractiveConfirmation": "allow"
  },
  "install": {
    "conflictPolicy": "overwrite-managed-only",
    "linkStrategy": "copy",
    "shellIntegration": "ask"
  },
  "smokeChecks": [
    {
      "name": "policy allows target command",
      "command": "scripts/test-command-policy kx 'kar -c kar-migration/config.ts'",
      "expectExit": 0
    },
    {
      "name": "policy allows shell chaining",
      "command": "scripts/test-command-policy kx 'kar -c kar-migration/config.ts && pwd'",
      "expectExit": 0
    },
    {
      "name": "path policy allows arbitrary edit",
      "command": "scripts/test-path-policy kx edit unrestricted-test.txt",
      "expectExit": 0
    }
  ],
  "compat": {
    "minPiVersion": "0.67.3",
    "testedPiVersions": [
      "0.67.3"
    ],
    "requiredPiFlags": [
      "--tools",
      "--append-system-prompt",
      "--session-dir",
      "--no-session"
    ],
    "optionalPiFlags": [
      "--no-context-files"
    ],
    "notes": "This recipe intentionally runs in yolo/full-access mode: Pi tool allowlists are not passed, resource discovery is not disabled, the pisolates guard is not loaded, and target CLI docs are appended at startup."
  },
  "docs": [
    "cli-docs.md"
  ]
}
