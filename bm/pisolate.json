{
  "schemaVersion": 1,
  "name": "bm",
  "version": "0.2.0",
  "description": "Conservative Pi harness for Basic Memory inspection and read/status workflows.",
  "category": "memory",
  "prompt": "prompt.md",
  "readme": "README.md",
  "oraclePlan": "oracle-plan.md",
  "defaultRoot": "~/.pisolates/work/bm",
  "targetCli": {
    "name": "bm",
    "preferredPath": "~/.local/bin/bm",
    "resolve": "path",
    "helpCommand": "bm --help"
  },
  "modes": {
    "interactive": {
      "kind": "interactive",
      "commands": ["pi-bm"],
      "policy": "read-only",
      "pi": {
        "mode": "interactive",
        "tools": ["bash"],
        "session": "save",
        "promptMode": "append",
        "disableAmbientResources": true,
        "disableContextFilesWhenSupported": true
      }
    },
    "oneShot": {
      "kind": "one-shot",
      "commands": ["p-bm"],
      "policy": "read-only",
      "pi": {
        "mode": "print",
        "tools": ["bash"],
        "session": "ephemeral",
        "promptMode": "append",
        "disableAmbientResources": true,
        "disableContextFilesWhenSupported": true
      }
    }
  },
  "requires": {
    "executables": [
      { "name": "pi", "command": "pi", "versionCommand": "pi --version" },
      { "name": "bm", "command": "bm", "versionCommand": "bm --version", "installHint": "Install Basic Memory CLI first." }
    ]
  },
  "commandPolicy": {
    "default": "deny",
    "shell": {
      "denyShellMetacharacters": true,
      "denyMultiline": true,
      "allowPipes": false,
      "allowRedirects": false
    },
    "allowed": [
      { "id": "bm-help", "match": "^bm (--help|-h|--version|-v)$", "kind": "help", "reason": "Shows CLI help/version only." },
      { "id": "bm-status-help", "match": "^bm status --help$", "kind": "help", "reason": "Shows status options without reading memory state." },
      { "id": "bm-status-local", "match": "^bm status --local( --json)?$", "kind": "read", "reason": "Reads local sync status only; --local avoids implicit cloud routing." },
      { "id": "bm-status-json-local", "match": "^bm status --json --local$", "kind": "read", "reason": "Reads local sync status only in machine-readable form; output must be summarized and redacted." },
      { "id": "bm-doctor-help", "match": "^bm doctor --help$", "kind": "help", "reason": "Shows doctor options without running checks." },
      { "id": "bm-doctor-local", "match": "^bm doctor --local$", "kind": "diagnostic", "reason": "Runs local consistency checks only; --local avoids implicit cloud routing." },
      { "id": "bm-project-help", "match": "^bm project --help$", "kind": "help", "reason": "Shows project subcommands only; no project state is read or mutated." },
      { "id": "bm-tool-help", "match": "^bm tool --help$", "kind": "help", "reason": "Shows MCP tool names only; no tool subcommand is executed." },
      { "id": "command-v-bm", "match": "^command -v bm$", "kind": "diagnostic", "reason": "Reports the resolved bm executable without invoking arbitrary shell utilities." },
      { "id": "pwd", "match": "^pwd$", "kind": "diagnostic", "reason": "Confirms the isolated working root." }
    ],
    "denied": [
      { "id": "bm-status-implicit-routing", "match": "^bm status$", "kind": "read", "reason": "Bare status may route through cloud mode; use bm status --local in this pisolate." },
      { "id": "bm-status-json-implicit-routing", "match": "^bm status --json$", "kind": "read", "reason": "JSON status without --local may route through cloud mode." },
      { "id": "bm-status-verbose", "match": "^bm status(\\s|$).*--verbose(\\s|$)", "kind": "private-metadata", "reason": "Verbose status can expose detailed private file information." },
      { "id": "bm-status-cloud", "match": "^bm status(\\s|$).*--cloud(\\s|$)", "kind": "cloud", "reason": "Cloud routing is outside the local-only first release." },
      { "id": "bm-status-project", "match": "^bm status(\\s|$).*--project(\\s|$)", "kind": "private-metadata", "reason": "Project selection needs confirmed path/config handling before release." },
      { "id": "bm-doctor-implicit-routing", "match": "^bm doctor$", "kind": "diagnostic", "reason": "Bare doctor may route through cloud mode; use bm doctor --local in this pisolate." },
      { "id": "bm-doctor-cloud", "match": "^bm doctor(\\s|$).*--cloud(\\s|$)", "kind": "cloud", "reason": "Cloud routing is outside the local-only first release." },
      { "id": "bm-reset", "match": "^bm reset(\\s|$)", "kind": "destructive", "confirmation": "type-phrase", "reason": "Drops and recreates the Basic Memory database." },
      { "id": "bm-import", "match": "^bm import(\\s|$)", "kind": "write", "confirmation": "confirm", "reason": "Imports external data into Basic Memory state." },
      { "id": "bm-format", "match": "^bm format(\\s|$)", "kind": "write", "confirmation": "confirm", "reason": "Formats files using configured formatters and can modify notes/files." },
      { "id": "bm-update", "match": "^bm update(\\s|$)", "kind": "write", "confirmation": "confirm", "reason": "May install updates." },
      { "id": "bm-reindex", "match": "^bm reindex(\\s|$)", "kind": "write", "confirmation": "confirm", "reason": "Rebuilds indexes or database-derived state." },
      { "id": "bm-mcp", "match": "^bm mcp(\\s|$)", "kind": "server", "confirmation": "confirm", "reason": "Starts an MCP server/transport and exposes a broader tool surface." },
      { "id": "bm-cloud", "match": "^bm cloud(\\s|$)", "kind": "cloud", "confirmation": "confirm", "reason": "Cloud access may expose credentials, workspaces, or private memory remotely." },
      { "id": "bm-tool-subcommands", "match": "^bm tool (write-note|read-note|edit-note|build-context|recent-activity|search-notes|list-projects|list-workspaces|schema-validate|schema-infer|schema-diff)(\\s|$)", "kind": "private-or-write", "confirmation": "confirm", "reason": "The bm tool surface mixes raw private memory reads/searches with memory writes; only bm tool --help is allowed in the first release." },
      { "id": "bm-tool-bare", "match": "^bm tool$", "kind": "ambiguous", "reason": "Bare bm tool behavior is not part of the verified first-release surface; use bm tool --help only." },
      { "id": "bm-project-list", "match": "^bm project list(\\s|$)", "kind": "private-metadata", "reason": "Project listing can reveal project names, paths, and cloud availability; defer until redaction is implemented." },
      { "id": "bm-project-ls", "match": "^bm project ls(\\s|$)", "kind": "private-metadata", "reason": "Lists files in a memory project and can expose private note names/paths." },
      { "id": "bm-project-info", "match": "^bm project info(\\s|$)", "kind": "private-metadata", "reason": "Can expose detailed project path/statistics; defer until redaction rules are implemented." },
      { "id": "bm-project-add", "match": "^bm project add(\\s|$)", "kind": "write", "confirmation": "confirm", "reason": "Adds a project and writes Basic Memory configuration." },
      { "id": "bm-project-remove", "match": "^bm project remove(\\s|$)", "kind": "write", "confirmation": "confirm", "reason": "Removes project registration and may affect local memory state." },
      { "id": "bm-project-default", "match": "^bm project default(\\s|$)", "kind": "write", "confirmation": "confirm", "reason": "Changes the default project configuration." },
      { "id": "bm-project-move", "match": "^bm project move(\\s|$)", "kind": "destructive", "confirmation": "type-phrase", "reason": "Moves a local project filesystem location." },
      { "id": "bm-project-set-cloud", "match": "^bm project set-cloud(\\s|$)", "kind": "cloud-write", "confirmation": "confirm", "reason": "Changes a project to cloud routing mode." },
      { "id": "bm-project-set-local", "match": "^bm project set-local(\\s|$)", "kind": "write", "confirmation": "confirm", "reason": "Changes project routing configuration." },
      { "id": "bm-schema", "match": "^bm schema(\\s|$)", "kind": "schema", "confirmation": "confirm", "reason": "Schema management behavior has not been captured for the first release." },
      { "id": "bm-install-completion", "match": "^bm --install-completion(\\s|$)", "kind": "write", "reason": "Installs shell completion and can modify shell configuration." },
      { "id": "bm-show-completion", "match": "^bm --show-completion(\\s|$)", "kind": "out-of-scope", "reason": "Shell completion generation is unrelated to Basic Memory inspection." }
    ],
    "writeCommands": [],
    "destructiveCommands": [],
    "sensitivePaths": [
      { "path": "~/.basic-memory", "policy": "no-direct-read", "reason": "Potential Basic Memory database/config/project state. Access only through allowed local bm commands." },
      { "path": "~/.config/basic-memory", "policy": "no-direct-read", "reason": "Potential Basic Memory config location; do not read or print config directly." },
      { "path": "~/.local/share/basic-memory", "policy": "no-direct-read", "reason": "Potential Basic Memory data/cache location; do not inspect directly." },
      { "path": "~/Library/Application Support/basic-memory", "policy": "no-direct-read", "reason": "Potential macOS app/support data location; do not inspect directly." },
      { "path": "user-configured Basic Memory project roots", "policy": "redact", "reason": "Project paths, note names, and note contents are private memory metadata/content." }
    ],
    "nonInteractiveConfirmation": "block"
  },
  "install": {
    "conflictPolicy": "overwrite-managed-only",
    "linkStrategy": "copy",
    "shellIntegration": "ask"
  },
  "smokeChecks": [
    { "name": "bm help", "command": "bm --help", "expectExit": 0, "expectStdout": "Basic Memory" },
    { "name": "policy allows local status", "command": "scripts/test-command-policy bm 'bm status --local'", "expectExit": 0 },
    { "name": "policy denies bare status", "command": "scripts/test-command-policy bm 'bm status'", "expectExit": 1 },
    { "name": "policy allows tool help", "command": "scripts/test-command-policy bm 'bm tool --help'", "expectExit": 0 },
    { "name": "policy denies tool read-note", "command": "scripts/test-command-policy bm 'bm tool read-note test'", "expectExit": 1 },
    { "name": "policy denies reset", "command": "scripts/test-command-policy bm 'bm reset'", "expectExit": 1 }
  ],
  "compat": {
    "minPiVersion": "0.67.3",
    "testedPiVersions": ["0.67.3"],
    "requiredPiFlags": ["--tools", "--append-system-prompt", "--session-dir", "--no-session"],
    "optionalPiFlags": ["--no-context-files"],
    "notes": "Substantial bm behavior remains gated by a bm-specific Oracle pass."
  }
}
