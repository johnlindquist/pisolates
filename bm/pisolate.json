{
  "schemaVersion": 1,
  "name": "bm",
  "version": "0.3.0",
  "description": "Full-access Pi harness for Basic Memory inspection and read/status workflows.",
  "category": "memory",
  "prompt": "prompt.md",
  "readme": "README.md",
  "oraclePlan": "oracle-plan.md",
  "defaultRoot": "~/.pisolates/work/bm",
  "targetCli": {
    "name": "bm",
    "preferredPath": "~/.local/bin/bm",
    "resolve": "path",
    "helpCommand": "bm --help"
  },
  "modes": {
    "interactive": {
      "kind": "interactive",
      "commands": [
        "pi-bm"
      ],
      "policy": "full-cli-access",
      "pi": {
        "mode": "interactive",
        "tools": [
          "bash"
        ],
        "session": "save",
        "promptMode": "append",
        "disableAmbientResources": true,
        "disableContextFilesWhenSupported": true
      }
    },
    "oneShot": {
      "kind": "one-shot",
      "commands": [
        "p-bm"
      ],
      "policy": "full-cli-access",
      "pi": {
        "mode": "print",
        "tools": [
          "bash"
        ],
        "session": "ephemeral",
        "promptMode": "append",
        "disableAmbientResources": true,
        "disableContextFilesWhenSupported": true
      }
    }
  },
  "requires": {
    "executables": [
      {
        "name": "pi",
        "command": "pi",
        "versionCommand": "pi --version"
      },
      {
        "name": "bm",
        "command": "bm",
        "versionCommand": "bm --version",
        "installHint": "Install Basic Memory CLI first."
      }
    ]
  },
  "commandPolicy": {
    "default": "allow",
    "shell": {
      "denyShellMetacharacters": false,
      "denyMultiline": false,
      "allowPipes": true,
      "allowRedirects": true
    },
    "allowed": [
      {
        "id": "all-commands",
        "match": "^.*$",
        "kind": "full-access",
        "reason": "Full CLI access is the default for this pisolate."
      }
    ],
    "denied": [],
    "writeCommands": [],
    "destructiveCommands": [],
    "sensitivePaths": [],
    "nonInteractiveConfirmation": "allow"
  },
  "install": {
    "conflictPolicy": "overwrite-managed-only",
    "linkStrategy": "copy",
    "shellIntegration": "ask"
  },
  "smokeChecks": [
    {
      "name": "policy allows target command",
      "command": "scripts/test-command-policy bm 'bm tool search-notes test'",
      "expectExit": 0
    },
    {
      "name": "policy allows shell chaining",
      "command": "scripts/test-command-policy bm 'bm tool search-notes test && pwd'",
      "expectExit": 0
    }
  ],
  "compat": {
    "minPiVersion": "0.67.3",
    "testedPiVersions": [
      "0.67.3"
    ],
    "requiredPiFlags": [
      "--tools",
      "--append-system-prompt",
      "--session-dir",
      "--no-session"
    ],
    "optionalPiFlags": [
      "--no-context-files"
    ],
    "notes": "This recipe intentionally defaults to full target-CLI access. Pisolates still provides isolated launcher/session/prompt structure, but command use is not curated."
  }
}
