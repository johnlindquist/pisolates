{
  "schemaVersion": 1,
  "name": "cx",
  "version": "0.3.0",
  "description": "Full-access cmux-aware Pi harness for read-only cmux context inspection and next-action drafting.",
  "category": "workspace",
  "prompt": "prompt.md",
  "readme": "README.md",
  "oraclePlan": "oracle-plan.md",
  "defaultRoot": "~/.pisolates/work/cx",
  "targetCli": "cmux",
  "modes": {
    "interactive": {
      "kind": "interactive",
      "commands": [
        "pi-cx"
      ],
      "policy": "full-cli-access",
      "pi": {
        "mode": "interactive",
        "tools": [
          "read",
          "bash",
          "edit",
          "write",
          "grep",
          "find",
          "ls"
        ],
        "session": "save",
        "promptMode": "append",
        "disableAmbientResources": true,
        "disableContextFilesWhenSupported": true,
        "yolo": true
      }
    },
    "oneShot": {
      "kind": "one-shot",
      "commands": [
        "p-cx"
      ],
      "policy": "full-cli-access",
      "pi": {
        "mode": "print",
        "tools": [
          "read",
          "bash",
          "edit",
          "write",
          "grep",
          "find",
          "ls"
        ],
        "session": "ephemeral",
        "promptMode": "append",
        "disableAmbientResources": true,
        "disableContextFilesWhenSupported": true,
        "yolo": true
      }
    }
  },
  "requires": {
    "executables": [
      {
        "name": "pi",
        "command": "pi",
        "versionCommand": "pi --version"
      },
      {
        "name": "cmux",
        "command": "cmux",
        "versionCommand": "cmux --help"
      }
    ]
  },
  "pathPolicy": {
    "default": "allow",
    "readable": [],
    "editable": [],
    "generatedReadOnly": [],
    "legacyReadOnly": [],
    "sensitiveDenied": [],
    "allowOutsideWorkingRoot": true
  },
  "commandPolicy": {
    "default": "allow",
    "shell": {
      "denyShellMetacharacters": false,
      "denyMultiline": false,
      "allowPipes": true,
      "allowRedirects": true
    },
    "allowed": [
      {
        "id": "all-commands",
        "match": "^.*$",
        "kind": "full-access",
        "reason": "Full CLI access is the default for this pisolate."
      }
    ],
    "denied": [],
    "writeCommands": [],
    "destructiveCommands": [],
    "sensitivePaths": [],
    "nonInteractiveConfirmation": "allow"
  },
  "install": {
    "conflictPolicy": "overwrite-managed-only",
    "linkStrategy": "copy",
    "shellIntegration": "ask"
  },
  "smokeChecks": [
    {
      "name": "policy allows target command",
      "command": "scripts/test-command-policy cx 'cmux new-workspace scratch'",
      "expectExit": 0
    },
    {
      "name": "policy allows shell chaining",
      "command": "scripts/test-command-policy cx 'cmux new-workspace scratch && pwd'",
      "expectExit": 0
    },
    {
      "name": "path policy allows arbitrary edit",
      "command": "scripts/test-path-policy cx edit unrestricted-test.txt",
      "expectExit": 0
    }
  ],
  "compat": {
    "minPiVersion": "0.67.3",
    "testedPiVersions": [
      "0.67.3"
    ],
    "requiredPiFlags": [
      "--no-extensions",
      "--no-skills",
      "--no-prompt-templates",
      "--no-themes",
      "--no-context-files",
      "--tools",
      "--append-system-prompt",
      "--session-dir",
      "--no-session"
    ],
    "optionalPiFlags": [],
    "notes": "This recipe intentionally runs in yolo/full-access mode for commands and built-in tools. Ambient Pi resource discovery is disabled, including global and cwd extensions, skills, prompt templates, themes, and context files. Target CLI docs are appended at startup from this recipe config."
  },
  "docs": [
    "cli-docs.md"
  ]
}
