#!/bin/sh
set -eu
repo=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
name=${1:-}
operation=${2:-}
target=${3:-}
[ -n "$name" ] && [ -n "$operation" ] && [ -n "$target" ] || {
  echo "usage: test-path-policy <name> <read|edit|write> <path>" >&2
  exit 2
}
manifest="$repo/$name/pisolate.json"
[ -f "$manifest" ] || manifest="${PISOLATES_HOME:-$HOME/.pisolates}/pisolates/$name/pisolate.json"
[ -f "$manifest" ] || {
  echo "missing manifest: $name" >&2
  exit 2
}
if [ -f "$repo/installer/json.mjs" ]; then
  exec "$repo/installer/json.mjs" path-policy "$manifest" "$operation" "$target"
fi
exec "${PISOLATES_HOME:-$HOME/.pisolates}/installer/json.mjs" path-policy "$manifest" "$operation" "$target"
